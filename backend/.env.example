# LLM Provider: anthropic, openai, or ollama
LLM_PROVIDER=
# Ollama model to use (e.g., deepseek-coder, mistral, llama2)
OLLAMA_MODEL=
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<database>"
# Use a dedicated read-only user for any SQL execution path.
READONLY_DATABASE_URL="postgresql://<readonly-username>:<password>@<host>:<port>/<database>"
# Optional: route query execution to read replicas only (never primary write nodes).
READ_REPLICA_DATABASE_URL="postgresql://<readonly-username>:<password>@<replica-host>:<port>/<database>"
CORS_ALLOW_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Optional: Anthropic API key (if using LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional: OpenAI API key (if using LLM_PROVIDER=openai)
# OPENAI_API_KEY="sk-..."